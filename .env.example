# Copy to .env for local dev. NEVER commit .env (it is gitignored).
# On the host (Render), set these as secrets instead of shipping a file.

# --- Django ---
# Generate a real one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-insecure-key-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Required once behind a domain, e.g. https://compliance.hector-garza.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Anthropic (used from M3; the model extracts and cites, never verdicts) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
